{
  "$schema": "http://json.schemastore.org/template",
  "author": "KoreForge",
  "classifications": [ "Library", "Data", "EFCore", "KoreForge" ],
  "identity": "KoreForge.Templates.Data",
  "name": "KoreForge Data Library",
  "shortName": "kf-data",
  "description": "A KoreForge EF Core data library with database-first scaffolding, partial DbContext, options, and DI registration.",
  "sourceName": "KF.Data.Alerts",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "symbols": {
    "DatabaseShort": {
      "type": "parameter",
      "datatype": "string",
      "description": "Short database name used in DbContext, options, and method names (e.g. Staff -> StaffDbContext, AddStaffDb).",
      "defaultValue": "Alerts",
      "replaces": "Alerts",
      "fileRename": "Alerts"
    }
  },
  "sources": [
    {
      "exclude": [
        ".template.config/**",
        "**/bin/**",
        "**/obj/**",
        "**/artifacts/**",
        "**/.vs/**",
        "**/*.user",
        "**/TestResults/**"
      ]
    }
  ],
  "postActions": [
    {
      "description": "Restore NuGet packages",
      "manualInstructions": [ { "text": "Run 'dotnet restore'" } ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "args": {
        "files": [ "src/**/*.csproj", "tst/**/*.csproj" ]
      },
      "continueOnError": true
    }
  ]
}
